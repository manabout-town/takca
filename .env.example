# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Toss Payments ───────────────────────────────────────────
# 테스트: test_ck_... / 라이브: live_ck_...
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ─── Anthropic (Claude AI — KYC 서류 분석) ───────────────────
ANTHROPIC_API_KEY=

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://takca.vercel.app

# ─── Vercel Cron (에스크로 72h 자동 해제) ────────────────────
# openssl rand -hex 32
CRON_SECRET=

# ─── 선택 (없으면 자동 스킵) ─────────────────────────────────
# 네이버 Clova OCR (KYC 정확도 향상)
NAVER_CLOVA_APIGW_URL=
NAVER_CLOVA_SECRET_KEY=

# 국세청 사업자번호 검증 (data.go.kr)
NTS_API_KEY=
